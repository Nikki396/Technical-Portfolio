{
  "name": "thames-exhibition",
  "version": "1.0.0",
  "description": "Thames River Exhibition Kiosk Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-win-portable": "electron-builder --win portable",
    "build-linux": "electron-builder --linux"
  },
  "keywords": [
    "exhibition",
    "kiosk",
    "art"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.thames.exhibition",
    "productName": "Thames Exhibition",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "control.html",
      "control.css",
      "control.js",
      "display.html",
      "display.css",
      "display.js",
      "image_database/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Graphics"
    }
  }
}